DISCORD_TOKEN=
# Optional: register slash commands to one guild (faster updates). Omit for global commands.
DISCORD_GUILD_ID=

# In Docker use host.docker.internal (not localhost). Compose sets extra_hosts for Linux.
# Ollama example: http://host.docker.internal:11434/v1 — also set OLLAMA_HOST=0.0.0.0 on the host.
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=local-model
LLM_API_KEY=

# Default: ./data/games.db (use /data/games.db in docker compose)
# DATABASE_PATH=./data/games.db

# LLM_SYSTEM_PROMPT=
