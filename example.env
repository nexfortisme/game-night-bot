DISCORD_TOKEN=
# Optional: register slash commands to one guild (faster updates). Omit for global commands.
DISCORD_GUILD_ID=

# Compose uses network_mode: host — use 127.0.0.1 (not host.docker.internal).
# Ollama (11434) / LM Studio (1234) — startup probes these ports.
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=local-model
LLM_API_KEY=

# Default: ./data/games.db (use /data/games.db in docker compose)
# DATABASE_PATH=./data/games.db

# LLM_SYSTEM_PROMPT=
